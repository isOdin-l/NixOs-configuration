{
	"label" : "shutdown",
	"action" : "systemctl poweroff",
	"text" : "Poweroff",
	"keybind" : "p"
}
{
	"label" : "reboot",
	"action" : "systemctl reboot",
	"text" : "Reboot",
	"keybind" : "r"
}
{
	"label" : "logout",
	"action" : "loginctl kill-session $XDG_SESSION_ID",
	"text" : "Logout",
	"keybind" : "m"
}
{
	"label" : "hibernate",
	"action" : "hyprlock -f && systemctl hibernate",
	"text" : "Hibernate",
	"keybind" : "h"
}
{
	"label" : "sleep",
	"action" : "systemctl suspend",
	"text" : "Sleep",
	"keybind" : "s"
}
{
	"label" : "lock",
	"action" : "hyprlock",
	"text" : "Lock",
	"keybind" : "l"
}
