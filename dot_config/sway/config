set $mod Mod4
set $terminal kitty
set $fileManager nemo
set $menu rofi -show drun -show-icons

seat seat0 xcursor_theme Catppuccin-Mocha-Dark-Cursors 24

output DP-1 resolution 1920x1200@60Hz position 0 0
output HDMI-A-1 resolution 1366x768@60Hz position 0 0

gaps inner 3
gaps outer 8
smart_gaps on
smart_borders on
default_border pixel 1
focus_follows_mouse yes
font pango:JetBrainsMono Nerd Font 11

client.focused          #ffffff66 #ffffff66 #cdd6f4 #ffffff66
client.unfocused        #ffffff33 #ffffff33 #cdd6f4 #ffffff33
client.focused_inactive #ffffff33 #ffffff33 #cdd6f4 #ffffff33
client.urgent           #f38ba8  #f38ba8  #cdd6f4 #f38ba8

input type:keyboard {
    xkb_layout us,ru
    xkb_options grp:alt_shift_toggle,caps:escape
    repeat_rate 25
    repeat_delay 600
}

input type:touchpad {
    natural_scroll enabled
    tap enabled
    pointer_accel -0.23
    accel_profile adaptive
}

for_window [class="microsoft-edge"] border pixel 1
for_window [class="Nemo"] floating enable, move position center
for_window [class="^$" shell="xwayland"] floating enable, focus disable

# launch
bindsym $mod+q exec $terminal
bindsym $mod+e exec $fileManager
bindsym $mod+s exec $menu
bindsym $mod+Menu exec qalculate-gtk

# close / exit
bindsym $mod+c kill
bindsym $mod+m exit

# toggle floating
bindsym $mod+v floating toggle

# layout
bindsym $mod+p layout toggle split
bindsym $mod+j split toggle

# screenshots
bindsym $mod+Shift+s exec grimshot copy area

# logout menu
bindsym $mod+Escape exec pkill wlogout || wlogout

# focus movement
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Up focus up
bindsym $mod+Down focus down

# workspace switching
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# move container to workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# scratchpad
bindsym $mod+b scratchpad show
bindsym $mod+Shift+b move scratchpad

# scroll through workspaces
bindsym $mod+button4 workspace prev
bindsym $mod+button5 workspace next

# move/resize with mouse
bindsym --whole-window $mod+button1 move
bindsym --whole-window $mod+button3 resize

# multimedia keys
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym --locked XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-

# media keys
bindsym --locked XF86AudioNext exec playerctl next
bindsym --locked XF86AudioPause exec playerctl play-pause
bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioPrev exec playerctl previous

# fix slow app startup
exec systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK
exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK

# autostart
exec gnome-keyring-daemon --start --components=secrets
exec swaybg -i /home/isodin/Pictures/Wallpapers/CatLeaves.png -m fill
exec nm-applet --indicator
exec dbus-launch waybar
exec dunst
exec wl-paste --watch cliphist store
